                local pct       = remaining / CONFIG["NoHitTimeout"]

                TimerBar.Size      = UDim2.new(pct, 0, 1, 0)
                tgrad.Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0, pct > 0.4 and C.accentOn or C.red),
                    ColorSequenceKeypoint.new(1, pct > 0.4 and C.accent   or C.gold),
                })

                if remaining > 0 then
                    TimerLbl.Text      = "⏱ " .. math.ceil(remaining) .. "s"
                    TimerLbl.TextColor3 = pct > 0.4 and C.sub or C.gold
