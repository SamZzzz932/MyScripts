-- ──────────────────────────────────
--  DETECTOR DE DAÑO A JUGADORES
-- ──────────────────────────────────
local function watchPlayer(p)
    if p == player then return end
    local function watchChar(char)
        pcall(function()
            local hum  = char:WaitForChild("Humanoid", 5)
            if not hum then return end
            local last = hum.Health
            hum:GetPropertyChangedSignal("Health"):Connect(function()
                local delta = last - hum.Health
                last = hum.Health
                if delta > 0 and State.active then
                    State.lastHitTime = os.clock()
                end
            end)
        end)
    end
    p.CharacterAdded:Connect(watchChar)
    if p.Character then watchChar(p.Character) end
end

for _, p in ipairs(Players:GetPlayers()) do watchPlayer(p) end
Players.PlayerAdded:Connect(watchPlayer)

pcall(function()
    local CommE = ReplicatedStorage:WaitForChild("Remotes", 5)
        :WaitForChild("CommE", 5)
    CommE.OnClientEvent:Connect(function(event, ...)
        if not State.active then return end
        if event ~= "Notify" then return end
        local msg = select(1, ...) or ""
        if msg:find("Bounty<Color=/> from") or msg:find("Honor<Color=/> from") then
            local earned = tonumber(string.match(msg, ">(%d+)")) or 0
            State.sessionEarned += earned
            State.kills         += 1
            State.lastHitTime    = os.clock()
            State.currentBounty  = getBounty()
            saveData()
        end
    end)
end)

task.spawn(function()
    while task.wait(1) do
        if not State.active then continue end

        if not hasValidTargets() then
            print("[ZBounty] Sin targets validos en el server → Hopeando")
            State.status = "Sin targets → Hopeando"
            task.wait(2)
            Hop(); task.wait(5)
            State.lastHitTime = os.clock()
            State.status = "Activo"
            continue
        end

        local sinceHit = os.clock() - State.lastHitTime
        if sinceHit >= CONFIG["NoHitTimeout"] then
            print("[ZBounty] " .. CONFIG["NoHitTimeout"] .. "s sin daño → Hopeando")
            State.status = "Hopeando..."
            saveData()
            Hop(); task.wait(5)
            State.lastHitTime = os.clock()
            State.status = "Activo"
        end
    end
end)

