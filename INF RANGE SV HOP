task.spawn(function()
    print("[ZBounty] Iniciando — Team=" .. CONFIG["Team"] .. " Weapon=" .. CONFIG["Weapon"])

    local confirmed = false
    local elapsed   = 0

    if player.Team and player.Team.Name == CONFIG["Team"] then
        print("[ZBounty] Ya somos " .. CONFIG["Team"])
        confirmed = true
    elseif player.Team then
        print("[ZBounty] Team actual: " .. player.Team.Name .. " (necesito " .. CONFIG["Team"] .. ")")
    else
        print("[ZBounty] Sin team — buscando pantalla...")
    end

    while not confirmed do
        task.wait(0.3); elapsed += 0.3

        selectFaction(CONFIG["Team"])
        task.wait(0.5)

        if player.Team and player.Team.Name == CONFIG["Team"] then
            print("[ZBounty] Faccion confirmada: " .. CONFIG["Team"])
            confirmed = true
            break
        end

        local ct = findChooseTeam()
        if ct and ct.Visible then
            print("[ZBounty] Pantalla visible → intentando seleccionar " .. CONFIG["Team"])
        end

        if elapsed >= 30 then
            print("[ZBounty] Timeout 30s — arrancando sin confirmar faccion")
            confirmed = true
        end
    end

    if player.Team and player.Team.Name == CONFIG["Team"] then
        StatBadge.Text = "● ACTIVO"
        StatBadge.BackgroundColor3 = C.accentOn
    else
        StatBadge.Text = "● SIN TEAM"
        StatBadge.BackgroundColor3 = C.gold
    end

    startAll()

    task.wait(2)
    if not hasValidTargets() then
        print("[ZBounty] Sin targets Lv." .. CONFIG["MinLevel"] .. "+ → Hopeando")
        State.status = "Sin targets → Hopeando"
        task.wait(2)
        Hop(); task.wait(5)
        State.lastHitTime = os.clock()
        State.status = "Activo"
    end
end)

task.spawn(function()
